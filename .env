# ─── Project ──────────────────────────────────────────────────────────────────
PROJECT_NAME="Education Process Platform"
ENVIRONMENT=local
FRONTEND_HOST=http://localhost:5173
DOMAIN=localhost
STACK_NAME=education-platform
DOCKER_IMAGE_BACKEND=education-platform-backend
DOCKER_IMAGE_FRONTEND=education-platform-frontend
TAG=latest

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
POSTGRES_DB=education_platform

# ─── First superuser ──────────────────────────────────────────────────────────
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (in addition to FRONTEND_HOST)
BACKEND_CORS_ORIGINS=

# ─── Email (optional) ─────────────────────────────────────────────────────────
# Leave blank to disable email sending
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=True
SMTP_SSL=False
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=

# ─── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Telegram Bot (optional) ──────────────────────────────────────────────────────
# Leave blank to disable Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Required for webhook: https://yourdomain.com or https://ngrok-subdomain.ngrok.io
BACKEND_PUBLIC_URL=